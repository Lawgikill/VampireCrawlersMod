{
  "name": "vampire-crawlers-deck-tracker",
  "version": "1.1.5",
  "private": true,
  "author": "Vampire Crawlers Deck Tracker contributors",
  "description": "Read-only second-screen deck tracker for Vampire Crawlers saves.",
  "main": "src/main.js",
  "scripts": {
    "start": "node server.js",
    "desktop": "electron .",
    "build:win": "electron-builder --win",
    "extract-art": "python tools\\extract_art.py --min-size 16",
    "build-card-map": "python tools\\build_card_map.py",
    "build-card-cost-map": "python tools\\build_card_cost_map.py",
    "build-evolutions": "python tools\\build_evolutions.py",
    "build-text-meta": "python tools\\build_text_meta.py",
    "build-local-data": "python tools\\build_local_data.py",
    "stage-live-bridge": "python tools\\stage_live_bridge_payload.py",
    "build-asset-builder": "python tools\\build_asset_builder.py"
  },
  "build": {
    "appId": "com.vampirecrawlers.decktracker",
    "productName": "Vampire Crawlers Deck Tracker",
    "artifactName": "Vampire-Crawlers-Deck-Tracker-Setup-${version}.${ext}",
    "directories": {
      "output": "dist"
    },
    "asar": false,
    "files": [
      "package.json",
      "requirements.txt",
      "data/**",
      "server.js",
      "src/**",
      "tools/**",
      "public/**",
      "!public/assets/art/**",
      "!public/assets/art-manifest.json",
      "!public/assets/card-map.json",
      "!public/assets/card-names.json",
      "!public/assets/gem-map.json",
      "!public/assets/contact-sheet-*.png"
    ],
    "extraResources": [
      {
        "from": "resources/live-bridge",
        "to": "live-bridge",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "bin",
        "to": "asset-builder",
        "filter": [
          "vampire-crawlers-asset-builder.exe"
        ]
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "Lawgikill",
        "repo": "VampireCrawlersMod"
      }
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "electron": "^38.4.0",
    "electron-builder": "^26.0.12"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
